@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="jumbotron jumbotron-fluid text-white text-center py-5 shadow-lg rounded-bottom" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); margin-top: -1rem;">
    <div class="container py-4">
        <h1 class="display-4 font-weight-bold mb-3">
            <i class="fas fa-shipping-fast"></i> LojiTech Sipariş & Lojistik Merkezi
        </h1>
        <p class="lead mb-4">7 farklı <strong>Tasarım Deseni (Design Pattern)</strong> ile inşa edilmiş, dinamik stok ve akıllı kargo yönetim platformu.</p>
        <hr class="my-4 bg-light w-25" style="opacity: 0.5;">
        <p class="mb-5 font-weight-light">Lütfen yapmak istediğiniz işlemi veya giriş yapmak istediğiniz paneli seçin.</p>

        @if (User.Identity.IsAuthenticated)
        {
            <a asp-controller="Order" asp-action="Index" class="btn btn-success btn-lg px-5 shadow m-2 rounded-pill">
                <i class="fas fa-shopping-cart"></i> Hemen Sipariş Ver
            </a>
            <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-light btn-lg px-5 shadow m-2 rounded-pill">
                <i class="fas fa-box-open"></i> Siparişlerim
            </a>
        }
        else
        {
            <a href="/Identity/Account/Login" class="btn btn-warning btn-lg px-5 shadow m-2 rounded-pill text-dark font-weight-bold">
                <i class="fas fa-sign-in-alt"></i> Sisteme Giriş Yap
            </a>
            <a href="/Identity/Account/Register" class="btn btn-outline-light btn-lg px-5 shadow m-2 rounded-pill">
                <i class="fas fa-user-plus"></i> Kayıt Ol
            </a>
        }
    </div>
</div>

<div class="container mt-5">
    <div class="row text-center mb-5">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="display-4 text-primary mb-3"><i class="fas fa-cogs"></i></div>
                    <h5 class="font-weight-bold">Akıllı Stok <br><small class="text-muted">(Observer & Composite)</small></h5>
                    <p class="text-muted small mt-3">Ürün stokları eşik değerin altına düştüğünde bildirimler gönderilir. Karmaşık ürünlerde alt parça stokları hiyerarşik olarak düşülür.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="display-4 text-warning mb-3"><i class="fas fa-truck-loading"></i></div>
                    <h5 class="font-weight-bold">Dinamik Lojistik <br><small class="text-muted">(Adapter & Decorator)</small></h5>
                    <p class="text-muted small mt-3">Farklı kargo firmalarının API'leri (Aras, Yurtiçi) tek arayüzden yönetilir. Sigorta gibi ek hizmetler çalışma anında siparişe sarılır.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="display-4 text-success mb-3"><i class="fas fa-shield-alt"></i></div>
                    <h5 class="font-weight-bold">Güvenli İşlem <br><small class="text-muted">(State & Singleton)</small></h5>
                    <p class="text-muted small mt-3">Sipariş durum geçişleri katı kurallara bağlıdır. Yapılan tüm kritik işlemler veritabanına tek bir merkez (Singleton) üzerinden loglanır.</p>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <div class="row mb-5 justify-content-center">
        <div class="col-12 text-center mb-4">
            <h3 class="font-weight-bold"><i class="fas fa-users-cog text-secondary"></i> Personel Hızlı Erişim</h3>
            <p class="text-muted">Yetkinize uygun yönetim paneline hızlıca geçiş yapabilirsiniz.</p>
        </div>

        <div class="col-md-5 mb-3">
            <div class="card border-left-warning shadow-sm" style="border-left: 4px solid #ffc107;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1 font-weight-bold"><i class="fas fa-warehouse text-warning"></i> Depo Yönetimi</h5>
                        <small class="text-muted">Stok girişi ve ürün oluşturma işlemleri.</small>
                    </div>
                    <a asp-controller="Order" asp-action="StokYonetimi" class="btn btn-sm btn-outline-warning">Giriş</a>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-3">
            <div class="card border-left-info shadow-sm" style="border-left: 4px solid #17a2b8;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1 font-weight-bold"><i class="fas fa-shipping-fast text-info"></i> Kurye Operasyon</h5>
                        <small class="text-muted">Sipariş durumu güncelleme işlemleri.</small>
                    </div>
                    <a asp-controller="Order" asp-action="KargoDurumu" class="btn btn-sm btn-outline-info">Giriş</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>