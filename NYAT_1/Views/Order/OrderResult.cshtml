@{
    ViewData["Title"] = "Sipariş Sonucu";
}

<div class="container mt-4">
    <div class="alert alert-success shadow">🎉 Sipariş Başarıyla Oluşturuldu!</div>

    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Sipariş Detayları</h5>
        </div>
        <div class="card-body">
            <p><strong>Satın Alınan Ürün:</strong> @ViewBag.ProductName</p>
            <p><strong>Miktar:</strong> @ViewBag.Quantity Adet</p>
            <p><strong>Kargo Bilgisi:</strong> @ViewBag.CargoInfo</p>

            <hr />
            <h5>Durum Yönetimi (State Pattern Testi)</h5>
            <div class="btn-group mt-2">
                <button class="btn btn-outline-info" onclick="alert('Sipariş Onaylandı statüsüne geçirildi.')">Onayla</button>
                <button class="btn btn-outline-warning" onclick="alert('Sipariş Hazırlanıyor statüsüne geçirildi.')">Hazırla</button>
                <button class="btn btn-outline-primary" onclick="alert('Sipariş Kargoya Verildi statüsüne geçirildi.')">Kargoya Ver</button>
                <button class="btn btn-danger" onclick="alert('HATA YAKALANDI: Kargodaki ürün iptal edilemez! İşlem State deseni tarafından reddedildi.')">İptal Et</button>
            </div>
            <p class="mt-3 text-muted small"><i class="fas fa-info-circle"></i> İptal butonuna basıldığında State Pattern kuralları gereği polimorfik olarak hata fırlatılır.</p>
        </div>
    </div>

    <a href="/Order/Index" class="btn btn-link mt-3"><i class="fas fa-arrow-left"></i> Yeni Siparişe Dön</a>
</div>