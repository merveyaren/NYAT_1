@{
    ViewData["Title"] = "Depo Stok Yönetimi";
}

<div class="container mt-4">
    <h2 class="text-warning mb-4">🏭 Depo Stok Yönetimi Paneli</h2>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <strong>➕ Yeni Ürün Kaydet (Factory)</strong>
                </div>
                <div class="card-body">
                    <form asp-controller="Order" asp-action="AddNewProduct" method="post">
                        <div class="form-group">
                            <label>Ürün Tipi</label>
                            <select name="productType" class="form-control">
                                <option value="Basit">Basit Ürün</option>
                                <option value="Karmasik">Karmaşık Ürün (Montajlı)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Ürün Adı</label>
                            <input type="text" name="productName" class="form-control" required placeholder="Örn: Mekanik Klavye">
                        </div>
                        <div class="form-group">
                            <label>Başlangıç Stoğu</label>
                            <input type="number" name="stock" class="form-control" value="10" min="0">
                        </div>
                        <div class="form-group">
                            <label>Birim Fiyat (TL)</label>
                            <input type="number" name="price" class="form-control" value="150" min="0">
                        </div>
                        <div class="form-group">
                            <label>Ürün Ağırlığı (KG)</label>
                            <input type="number" name="weight" class="form-control" value="1.0" step="0.1" min="0.1">
                        </div>
                        <div class="form-group border p-2 bg-light rounded mt-2">
                            <label class="text-info font-weight-bold">Alt Parçalar <small>(Sadece Karmaşık Ürünler İçin)</small></label>
                            <select name="selectedComponents" class="form-control" multiple size="4">
                                @if (ViewBag.SimpleProducts != null)
                                {
                                    foreach (var sp in ViewBag.SimpleProducts)
                                    {
                                        <option value="@sp.Name">@sp.Name (Stok: @sp.Stock)</option>
                                    }
                                }
                            </select>
                            <small class="text-muted">Ctrl tuşuna basılı tutarak birden fazla parça seçebilirsiniz.</small>
                        </div>
                        <button type="submit" class="btn btn-success btn-block">Veritabanına Kaydet</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <strong>📦 Mevcut Stokları Güncelle</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Veritabanındaki ürünlerin stoklarını buradan arttırabilirsiniz.</p>

                    <form asp-controller="Order" asp-action="IncreaseStock" method="post">
                        <div class="form-group">
                            <label>Ürün Seçin</label>
                            <select name="productName" class="form-control">
                                @if (ViewBag.Products != null)
                                {
                                    foreach (var item in ViewBag.Products)
                                    {
                                        <option value="@item.Name">@item.Name (Mevcut: @item.Stock Adet)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Eklenecek Miktar</label>
                            <input type="number" name="amount" class="form-control" value="5" min="1">
                        </div>
                        <button type="submit" class="btn btn-warning btn-block">Stok Ekle</button>
                    </form>

                    <hr />

                    <table class="table table-sm mt-3">
                        <thead class="thead-light">
                            <tr>
                                <th>Ürün</th>
                                <th>Tip</th>
                                <th>Stok</th>
                                <th>Fiyat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Products != null)
                            {
                                foreach (var item in ViewBag.Products)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td><span class="badge badge-info">@item.ProductType</span></td>
                                        <td>
                                            <b class="@(item.Stock < 5 ? "text-danger" : "text-dark")">@item.Stock</b>
                                        </td>
                                        <td>@item.Price TL</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-secondary mt-4">
        <small>
            <b>Sistem Notu:</b> Yeni ürün eklerken <strong>Factory Method</strong>, stok düşerken <strong>Observer</strong> ve tüm bu işlemler sırasında <strong>Singleton Loglama</strong> desenleri aktif olarak çalışmaktadır.
        </small>
    </div>
</div>