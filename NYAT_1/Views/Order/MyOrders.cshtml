@model IEnumerable<NYAT_1.Models.OrderRecord>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4"><i class="fas fa-box-open"></i> Sipariş Geçmişim</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm">
            <strong>State Deseni Kural İhlali:</strong> @TempData["ErrorMessage"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Ürün</th>
                        <th>Adet</th>
                        <th>Durum (State)</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><strong>@order.ProductName</strong></td>
                                <td>@order.Quantity</td>
                                <td>
                                    <span class="badge @(order.Status == "Beklemede" ? "badge-secondary" : order.Status == "Kargoda" ? "badge-primary" : order.Status == "İptal Edildi" ? "badge-danger" : "badge-info")">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <form asp-action="CancelMyOrder" method="post" style="display:inline;">
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" @(order.Status == "İptal Edildi" ? "disabled" : "")>
                                            İptal Et
                                        </button>
                                    </form>

                                    @if (order.Status == "Kargoda" || order.Status == "Teslim Edildi")
                                    {
                                        <button class="btn btn-sm btn-outline-warning ml-2" onclick="alert('İade süreci başlatıldı.')">İade Et</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted p-4">Henüz bir siparişiniz bulunmuyor.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>