@{
    ViewData["Title"] = "Sipariş Oluştur";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white p-3">
            <h3 class="mb-0"><i class="fas fa-shopping-cart"></i> Yeni Sipariş Oluştur</h3>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Order" asp-action="ProcessOrder" method="post">
                
                <div class="row">
                    <div class="col-md-8 mb-4">
                        <label class="font-weight-bold">Satın Alınacak Ürün</label>
                        <select name="productName" id="productSelect" class="form-control form-control-lg" required onchange="calculateTotal()">
                            <option value="" data-price="0">-- Lütfen bir ürün seçin --</option>
                            @if (ViewBag.Products != null)
                            {
                                foreach (var product in ViewBag.Products)
                                {
                                    <option value="@product.Name" data-price="@product.Price" disabled="@(product.Stock <= 0 ? "disabled" : null)">
                                        @product.Name - (@product.Price TL) - Stok: @product.Stock
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Adet</label>
                        <input type="number" name="quantity" id="quantityInput" class="form-control form-control-lg" value="1" min="1" required oninput="calculateTotal()">
                    </div>

                    <div class="col-12 mb-4">
                        <div class="alert alert-dark d-flex justify-content-between align-items-center shadow-sm">
                            <h4 class="mb-0">Toplam Tutar:</h4>
                            <h4 class="mb-0 text-success"><span id="totalPriceDisplay">0.00</span> TL</h4>
                        </div>
                    </div>
                </div>

                <script>
                    function calculateTotal() {
                        const select = document.getElementById('productSelect');
                        const quantity = document.getElementById('quantityInput').value;
                        const selectedOption = select.options[select.selectedIndex];
                        
                        const price = parseFloat(selectedOption.getAttribute('data-price')) || 0;
                        
                        const insuranceCheck = document.getElementById('chkInsurance');
                        let extra = 0;
                        if (insuranceCheck && insuranceCheck.checked) {
                            extra = 50;
                        }

                        const total = (price * quantity) + extra;
                        document.getElementById('totalPriceDisplay').innerText = total.toLocaleString('tr-TR', { minimumFractionDigits: 2 });
                    }

                    document.addEventListener('DOMContentLoaded', function() {
                        const chk = document.getElementById('chkInsurance');
                        if(chk) chk.addEventListener('change', calculateTotal);
                    });
                </script>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Ödeme Yöntemi</label>
                        <select name="paymentMethod" class="form-control">
                            <option value="CreditCard">Kredi Kartı</option>
                            <option value="BankTransfer">Banka Havalesi</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Kargo Firması</label>
                        <select name="cargoCompany" class="form-control">
                            <option value="Yurtici">Yurtiçi Kargo</option>
                            <option value="Aras">Aras Kargo</option>
                            
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Ek Hizmetler</label>
                        <div class="border rounded p-2 bg-light">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" name="useInsurance" value="true" class="custom-control-input" id="chkInsurance">
                                <label class="custom-control-label" for="chkInsurance">Sigorta (+50 TL)</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <p class="text-muted small mb-0">
                        * Sipariş onaylandığında <strong>Strategy</strong> ve <strong>Decorator</strong> desenleri çalıştırılacaktır.
                    </p>
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow">Siparişi Tamamla</button>
                </div>
            </form>
        </div>
    </div>
</div>