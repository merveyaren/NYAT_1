@{
    ViewData["Title"] = "Sipariş Oluştur";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white p-3">
            <h3 class="mb-0"><i class="fas fa-shopping-cart"></i> Yeni Sipariş Oluştur</h3>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Order" asp-action="ProcessOrder" method="post">

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Satın Alınacak Ürün</label>
                        <select name="productName" id="productSelect" class="form-control form-control-lg" required onchange="calculateTotal()">
                            <option value="" data-price="0" data-weight="0">-- Ürün Seçin --</option>
                            @if (ViewBag.Products != null)
                            {
                                foreach (var product in ViewBag.Products)
                                {
                                    <option value="@product.Name"
                                            data-price="@Convert.ToString(product.Price, System.Globalization.CultureInfo.InvariantCulture)"
                                            data-weight="@Convert.ToString(product.Weight, System.Globalization.CultureInfo.InvariantCulture)"
                                            disabled="@(product.Stock <= 0 ? "disabled" : null)">
                                        @product.Name - (@product.Price TL) - @product.Weight KG
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Adet</label>
                        <input type="number" name="quantity" id="quantityInput" class="form-control form-control-lg" value="1" min="1" required oninput="calculateTotal()">
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Teslimat Mesafesi (KM)</label>
                        <input type="number" name="distance" id="distanceInput" class="form-control form-control-lg" value="10" min="1" required oninput="calculateTotal()">
                    </div>

                    <div class="col-12 mb-4">
                        <div class="alert alert-dark d-flex justify-content-between align-items-center shadow-sm">
                            <h4 class="mb-0">Tahmini Toplam Tutar:</h4>
                            <h4 class="mb-0 text-success"><span id="totalPriceDisplay">0.00</span> TL</h4>
                        </div>
                    </div>
                </div>

                <script>
                    function calculateTotal() {
                        try {
                            const select = document.getElementById('productSelect');
                            const qtyInput = document.getElementById('quantityInput');
                            const distInput = document.getElementById('distanceInput');
                            const cargoSelect = document.getElementById('cargoSelect'); // Kargo seçimini yakala

                            if (!select || !qtyInput || !distInput || !cargoSelect) return;

                            const quantity = parseInt(qtyInput.value) || 0;
                            const distance = parseFloat(distInput.value) || 0;

                            if (select.selectedIndex <= 0) {
                                document.getElementById('totalPriceDisplay').innerText = "0.00";
                                return;
                            }

                            const selectedOption = select.options[select.selectedIndex];
                            const unitPrice = parseFloat(selectedOption.getAttribute('data-price')) || 0;
                            let unitWeight = parseFloat(selectedOption.getAttribute('data-weight'));

                            if (unitWeight === 0 || isNaN(unitWeight)) {
                                unitWeight = 1.0;
                            }

                            const totalWeight = unitWeight * quantity;
                            const cargoCompany = cargoSelect.value;
                            let shippingCost = 0;

                            // ADAPTER KURALLARININ ARAYÜZ SİMÜLASYONU
                            if (cargoCompany === "Yurtici") {
                                // Yurtiçi Kargo Formülü (MESAFE YOK!)
                                shippingCost = (totalWeight * 2.5) + 20;
                            }
                            else if (cargoCompany === "Aras") {
                                // Aras Kargo Formülü
                                shippingCost = (totalWeight * 1.5) + (distance * 0.5);
                            }
                            else if (cargoCompany === "Global") {
                                // Global Express Formülü
                                shippingCost = (totalWeight * 20) + (distance * 1.5);
                            }

                            const insuranceCheck = document.getElementById('chkInsurance');
                            let insuranceExtra = (insuranceCheck && insuranceCheck.checked) ? 50 : 0;

                            const total = (unitPrice * quantity) + shippingCost + insuranceExtra;

                            document.getElementById('totalPriceDisplay').innerText = total.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                        } catch (e) {
                            console.error("Hesaplama sırasında hata oluştu:", e);
                        }
                    }

                    document.addEventListener('DOMContentLoaded', function() {
                        const chk = document.getElementById('chkInsurance');
                        if(chk) chk.addEventListener('change', calculateTotal);
                        calculateTotal();
                    });
                </script>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Ödeme Yöntemi</label>
                        <select name="paymentMethod" class="form-control">
                            <option value="CreditCard">Kredi Kartı</option>
                            <option value="BankTransfer">Banka Havalesi</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Kargo Firması</label>
                        <select name="cargoCompany" id="cargoSelect" class="form-control" onchange="calculateTotal()">
                            <option value="Yurtici">Yurtiçi Kargo (Sadece Ağırlık)</option>
                            <option value="Aras">Aras Kargo (Ağırlık + Mesafe)</option>
                            
                        </select>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="font-weight-bold">Ek Hizmetler</label>
                        <div class="border rounded p-2 bg-light">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" name="useInsurance" value="true" class="custom-control-input" id="chkInsurance">
                                <label class="custom-control-label" for="chkInsurance">Sigorta (+50 TL)</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <p class="text-muted small mb-0">
                        * Sipariş onaylandığında <strong>Strategy</strong> ve <strong>Decorator</strong> desenleri çalıştırılacaktır.
                    </p>
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow">Siparişi Tamamla</button>
                </div>
            </form>
        </div>
    </div>
</div>